LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_TOKEN=your_line_channel_access_token
PORT=8080
BOT_CONFIG_PATH=/app/configs/faq_seed.yaml
ENABLE_PPROF=false
EVENT_DEDUP_TTL=24h

# SQLite database path for user→diagnosis mapping
DB_PATH=/app/data/users.db

# image source
IMAGE_REGISTRY=ghcr.io
IMAGE_REPOSITORY=owner/obgynrama-chatbot
IMAGE_TAG=latest

# required for Caddy automatic TLS
DOMAIN=bot.example.com
